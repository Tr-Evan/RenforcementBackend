{
  "info": {
    "name": "Assurmoi API - Complete CRUD",
    "description": "API routes for Assurmoi NodeJS backend with all CRUD operations.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Users",
      "item": [
        { "name": "Get all users", "request": { "method": "GET", "url": "{{baseUrl}}/users" } },
        { "name": "Get user by ID", "request": { "method": "GET", "url": "{{baseUrl}}/users/1" } },
        { "name": "Create user", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"email\":\"newuser@example.com\",\"password_hash\":\"secret\",\"firstname\":\"John\",\"lastname\":\"Doe\",\"role_id\":1,\"status\":\"active\"}" }, "url": "{{baseUrl}}/users" } },
        { "name": "Update user", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"firstname\":\"Johnny\"}" }, "url": "{{baseUrl}}/users/2" } },
        { "name": "Delete user", "request": { "method": "DELETE", "url": "{{baseUrl}}/users/3" } }
      ]
    },
    {
      "name": "Roles",
      "item": [
        { "name": "Get all roles", "request": { "method": "GET", "url": "{{baseUrl}}/roles" } },
        { "name": "Get role by ID", "request": { "method": "GET", "url": "{{baseUrl}}/roles/1" } },
        { "name": "Create role", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"label\":\"SuperAdmin\"}" }, "url": "{{baseUrl}}/roles" } },
        { "name": "Update role", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"label\":\"Updated Admin\"}" }, "url": "{{baseUrl}}/roles/1" } },
        { "name": "Delete role", "request": { "method": "DELETE", "url": "{{baseUrl}}/roles/1" } }
      ]
    },
    {
      "name": "Sinistres",
      "item": [
        { "name": "Get all sinistres", "request": { "method": "GET", "url": "{{baseUrl}}/sinistres" } },
        { "name": "Get sinistre by ID", "request": { "method": "GET", "url": "{{baseUrl}}/sinistres/1" } },
        { "name": "Create sinistre", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"reference\":\"SIN-999\",\"immatriculation\":\"ZZ-999-ZZ\",\"conducteur_nom\":\"Test\",\"conducteur_prenom\":\"User\",\"is_conducteur_assure\":true,\"date_appel\":\"2026-03-25T10:00:00Z\",\"date_accident\":\"2026-03-24T08:00:00Z\",\"contexte\":\"Choc arrière\",\"responsabilite_pourcentage\":0,\"status_validation\":\"en_attente\",\"created_by_id\":1,\"assure_id\":2}" }, "url": "{{baseUrl}}/sinistres" } },
        { "name": "Update sinistre", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"status_validation\":\"valide\"}" }, "url": "{{baseUrl}}/sinistres/1" } },
        { "name": "Delete sinistre", "request": { "method": "DELETE", "url": "{{baseUrl}}/sinistres/1" } }
      ]
    },
    {
      "name": "Dossiers Prise En Charge",
      "item": [
        { "name": "Get all dossiers", "request": { "method": "GET", "url": "{{baseUrl}}/dossiers" } },
        { "name": "Get dossier by ID", "request": { "method": "GET", "url": "{{baseUrl}}/dossiers/1" } },
        { "name": "Create dossier", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"num_dossier\":\"DOS-TEST\",\"sinistre_id\":1,\"current_step_id\":1,\"scenario_type\":1,\"date_expertise_planifiee\":\"2026-04-01\",\"diagnostic_reparable\":true,\"montant_indemnisation\":1500.50,\"is_clos\":false}" }, "url": "{{baseUrl}}/dossiers" } },
        { "name": "Update dossier", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"is_clos\":true}" }, "url": "{{baseUrl}}/dossiers/1" } },
        { "name": "Delete dossier", "request": { "method": "DELETE", "url": "{{baseUrl}}/dossiers/1" } }
      ]
    },
    {
      "name": "Workflow Steps",
      "item": [
        { "name": "Get all workflow steps", "request": { "method": "GET", "url": "{{baseUrl}}/workflow-steps" } },
        { "name": "Get step by ID", "request": { "method": "GET", "url": "{{baseUrl}}/workflow-steps/1" } },
        { "name": "Create step", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"label\":\"Étape Supplémentaire\",\"order_index\":7}" }, "url": "{{baseUrl}}/workflow-steps" } },
        { "name": "Update step", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"label\":\"Ouverture modifiée\"}" }, "url": "{{baseUrl}}/workflow-steps/1" } },
        { "name": "Delete step", "request": { "method": "DELETE", "url": "{{baseUrl}}/workflow-steps/1" } }
      ]
    },
    {
      "name": "Documents",
      "item": [
        { "name": "Get all documents", "request": { "method": "GET", "url": "{{baseUrl}}/documents" } },
        { "name": "Get document by ID", "request": { "method": "GET", "url": "{{baseUrl}}/documents/1" } },
        { "name": "Create document", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"sinistre_id\":1,\"dossier_id\":1,\"type_document\":\"photo\",\"url_storage\":\"http://storage.com/photo.jpg\",\"is_validated\":false}" }, "url": "{{baseUrl}}/documents" } },
        { "name": "Update document", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"is_validated\":true,\"validated_by_id\":1}" }, "url": "{{baseUrl}}/documents/1" } },
        { "name": "Delete document", "request": { "method": "DELETE", "url": "{{baseUrl}}/documents/1" } }
      ]
    },
    {
      "name": "Logs Actions",
      "item": [
        { "name": "Get all logs", "request": { "method": "GET", "url": "{{baseUrl}}/logs-actions" } },
        { "name": "Get log by ID", "request": { "method": "GET", "url": "{{baseUrl}}/logs-actions/1" } },
        { "name": "Create log", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"entity_type\":\"user\",\"entity_id\":1,\"user_id\":1,\"action_description\":\"Test action\",\"old_status\":\"inactive\",\"new_status\":\"active\"}" }, "url": "{{baseUrl}}/logs-actions" } },
        { "name": "Update log", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"action_description\":\"Action mise à jour\"}" }, "url": "{{baseUrl}}/logs-actions/1" } },
        { "name": "Delete log", "request": { "method": "DELETE", "url": "{{baseUrl}}/logs-actions/1" } }
      ]
    }
  ]
}